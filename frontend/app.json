{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Nutzt die Kamera-LED als Morse-Taschenlampe",
        "NSMicrophoneUsageDescription": "Empfängt und dekodiert Morsetöne über das Mikrofon",
        "NSLocationWhenInUseUsageDescription": "Zeigt Amateurfunk-Repeater in deiner Nähe"
      },
      "bundleIdentifier": "com.emergent.funktoolbox.b246aq"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.emergent.funktoolbox.b246aq"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Nutzt die Kamera-LED als Morse-Taschenlampe"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-stream-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Zeigt Amateurfunk-Repeater in deiner Nähe"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8fe7513-6a19-4f85-9e45-c5ac9e2ed6dc"
      }
    }
  }
}
